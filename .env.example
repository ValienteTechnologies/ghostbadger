# Copy to .env and fill in values before running.
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=replace-with-a-long-random-string

# Base URL of your Ghostwriter instance (no trailing slash)
GHOSTWRITER_URL=https://ghostwriter.example.com

# Vaultwarden integration (optional — leave blank to disable)
# CLIENT_ID, CLIENT_SECRET, MASTER_PASSWORD are entered in the UI at connect time
VAULTWARDEN_URL=https://vault.example.com
VAULTWARDEN_ORG_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VAULTWARDEN_COLLECTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
